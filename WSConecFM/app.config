<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="Timbrado_ManagerBinding">
                    <security mode="Transport" />
                </binding>
                <binding name="Timbrado_ManagerBinding1" />
                <binding name="Timbrado_ManagerBinding2">
                    <security mode="Transport" />
                </binding>
                <binding name="Timbrado_ManagerBinding3" />
            </basicHttpBinding>
        </bindings>
        <client>
            <endpoint address="https://t2.facturacionmoderna.com/timbrado/soap"
                binding="basicHttpBinding" bindingConfiguration="Timbrado_ManagerBinding"
                contract="WSLayoutFacturacionModerna.Timbrado_ManagerPort"
                name="Timbrado_ManagerPort" />
            <endpoint address="https://t2.facturacionmoderna.com/timbrado/soap"
                binding="basicHttpBinding" bindingConfiguration="Timbrado_ManagerBinding2"
                contract="WSLayoutFacturacionModernaNeue.Timbrado_ManagerPort"
                name="Timbrado_ManagerPort1" />
        </client>
    </system.serviceModel>
</configuration>